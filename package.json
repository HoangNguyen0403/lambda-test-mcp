{
  "name": "lambda-test-mcp",
  "version": "1.1.2",
  "description": "MCP server for LambdaTest Automation — fetch sessions, logs, and video URLs.",
  "type": "module",
  "author": {
    "name": "Hoang Nguyen",
    "email": "hoanghuynguyen0403@gmail.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "lambda-test-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "release": "standard-version",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lambdatest",
    "automation",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoangNguyen0403/lambda-test-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/HoangNguyen0403/lambda-test-mcp/issues"
  },
  "homepage": "https://github.com/HoangNguyen0403/lambda-test-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-prettier": "^3.1.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "nock": "^14.0.12",
    "prettier": "^3.8.2",
    "standard-version": "^9.5.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1"
  }
}
